// Hard-coded IP addresses - VULNERABILITY FOR SAST TESTING
string databaseServer = "192.168.1.100";
string apiEndpoint = "http://10.0.0.50:8080/api";
string backupServer = "172.16.0.25";

// Hard-coded localhost variations - VULNERABILITY FOR SAST TESTING
string localService = "http://127.0.0.1:3000";
string internalAPI = "http://0.0.0.0:5000";
            </pre>
        </div>
    </div>

    <!-- Debug Features in Production -->
    <div class="card mb-4">
        <div class="card-header bg-danger text-white">
            <h5>🔓 Vulnerability: Debug Features in Production</h5>
        </div>
        <div class="card-body">
            <p class="text-muted">Example of debug code (SAST should detect this)</p>
            <pre class="bg-light p-3">
// Debug output in production - VULNERABILITY FOR SAST TESTING
public void ProcessData(string data) {
    Console.WriteLine("DEBUG: Processing data: " + data);  // VULNERABILITY
    Debug.WriteLine("Processing: " + data);  // VULNERABILITY
    
    // Stack trace exposure - VULNERABILITY FOR SAST TESTING
    try {
        // Some processing
    } catch (Exception ex) {
        Response.Write("Error: " + ex.StackTrace);  // VULNERABILITY
    }
}
            </pre>
        </div>
    </div>

    <!-- CSRF Vulnerability -->
    <div class="card mb-4">
        <div class="card-header bg-danger text-white">
            <h5>🔓 Vulnerability: CSRF Protection Disabled</h5>
        </div>
        <div class="card-body">
            <p class="text-muted">Example of disabled CSRF protection (SAST should detect this)</p>
            <pre class="bg-light p-3">
// CSRF protection disabled - VULNERABILITY FOR SAST TESTING
public void ConfigureServices(IServiceCollection services) {
    services.AddControllersWithViews(options => {
        options.Filters.Add(new AutoValidateAntiforgeryTokenAttribute()); // REMOVED - VULNERABILITY
    });
    
    // Explicitly disable CSRF - VULNERABILITY FOR SAST TESTING
    services.AddAntiforgery(options => {
        options.Cookie.Name = "X-CSRF-TOKEN";
        options.HeaderName = "X-CSRF-TOKEN";
        options.SuppressXFrameOptionsHeader = true; // VULNERABILITY
    });
}

// Action without CSRF token - VULNERABILITY FOR SAST TESTING
[HttpPost]
[IgnoreAntiforgeryToken]  // VULNERABILITY
public IActionResult TransferFunds(string toAccount, decimal amount) {
    // Process fund transfer without CSRF validation
    return Ok("Transfer completed");
}
            </pre>
        </div>
    </div>

    <!-- Excessive Content Length -->
    <div class="card mb-4">
        <div class="card-header bg-danger text-white">
            <h5>🔓 Vulnerability: Excessive Content Length</h5>
        </div>
        <div class="card-body">
            <p class="text-muted">Example of unlimited content length (SAST should detect this)</p>
            <pre class="bg-light p-3">
// Unlimited request size - VULNERABILITY FOR SAST TESTING
public void Configure(IApplicationBuilder app, IWebHostEnvironment env) {
    app.Use(async (context, next) => {
        context.Features.Get&lt;IHttpMaxRequestBodySizeFeature&gt;().MaxRequestBodySize = null;
        await next();
    });
}

// Large file upload without limits - VULNERABILITY FOR SAST TESTING
public async Task&lt;IActionResult&gt; UploadFile(IFormFile file) {
    // No file size validation - VULNERABILITY
    var content = await new StreamReader(file.OpenReadStream()).ReadToEndAsync();
    return Ok("File uploaded: " + content.Length + " bytes");
}
            </pre>
        </div>
    </div>

    <div class="alert alert-info">
        <h5>📋 SAST Testing Checklist</h5>
        <p>Use this page to test your SAST tools for the following vulnerability types:</p>
        <ul>
            <li>✅ Hard-coded credentials and secrets</li>
            <li>✅ SQL injection vulnerabilities</li>
            <li>✅ Cross-site scripting (XSS)</li>
            <li>✅ Weak cryptographic algorithms</li>
            <li>✅ Insecure cookie configuration</li>
            <li>✅ Hard-coded IP addresses</li>
            <li>✅ Debug features in production</li>
            <li>✅ Excessive content length</li>
        </ul>
    </div>
</div>
